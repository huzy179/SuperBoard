# Root shared environment template
NODE_ENV=development

# Ports
API_PORT=4000
WEB_PORT=3000
COLLAB_SERVICE_PORT=1234
COLLABORATION_PORT=3001
NOTIFICATION_PORT=3002
AUTOMATION_PORT=3004
AI_HTTP_PORT=8000
AI_GRPC_PORT=50051

# Database
POSTGRES_DB=superboard
POSTGRES_USER=dev
POSTGRES_PASSWORD=devpassword
DATABASE_URL=postgresql://dev:devpassword@localhost:5433/superboard

# Redis
REDIS_URL=redis://localhost:6379
ENABLE_REDIS=false

# Queue/Bull
ENABLE_QUEUE=false
QUEUE_NAME=superboard-dev

# RabbitMQ
RABBITMQ_USER=superboard
RABBITMQ_PASS=password
RABBITMQ_VHOST=superboard
RABBITMQ_URL=amqp://superboard:password@localhost:5672/superboard
RABBITMQ_PREFETCH_COUNT=10
ENABLE_RABBITMQ_EVENT_BUS=false
RABBITMQ_PUBLISH_MAX_RETRIES=3
RABBITMQ_PUBLISH_BACKOFF_BASE_MS=1000

# Search/Storage/Monitoring
ELASTICSEARCH_URL=http://localhost:9200
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
GRAFANA_ADMIN_PASSWORD=admin

# Auth/Security
JWT_SECRET=superboard-local-jwt-secret-change-me
JWT_EXPIRES_IN=1d
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_DB_PASSWORD=devpassword

# AI provider
AI_PROVIDER=gemini
GEMINI_API_KEY=
OPENAI_API_KEY=
AMQP_URL=amqp://superboard:password@localhost:5672/superboard
AMQP_PREFETCH_COUNT=10
GRPC_HOST=localhost
GRPC_PORT=50051

# App endpoints
FRONTEND_URL=http://localhost:3000
API_URL=http://localhost:4000
AI_SERVICE_URL=http://localhost:8000
CORE_API_URL=http://localhost:4000

# Web public env
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=ws://localhost:4000
NEXT_PUBLIC_AI_SERVICE_URL=http://localhost:8000

# Notification service
NOTIF_RETRY_MAX=5
