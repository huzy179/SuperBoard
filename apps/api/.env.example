# apps/api/.env.example
NODE_ENV=development
PORT=4000

# Database
DATABASE_URL=postgresql://dev:devpassword@localhost:5433/superboard

# Redis
REDIS_URL=redis://localhost:6379

# Search
ELASTICSEARCH_URL=http://localhost:9200

# Queue
QUEUE_NAME=superboard-dev

# App URLs
FRONTEND_URL=http://localhost:3000
AI_SERVICE_URL=http://localhost:8000

# Optional auth placeholders
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=superboard
KEYCLOAK_CLIENT_ID=superboard-app
KEYCLOAK_CLIENT_SECRET=replace-me
