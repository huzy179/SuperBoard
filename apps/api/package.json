{
  "name": "@superboard/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npx nest start --watch",
    "build": "npx nest build",
    "start": "node dist/main.js",
    "test": "node --test --import tsx",
    "test:workflow-lifecycle": "node --test --import tsx test/services/workspace.service.test.ts test/services/project.service.test.ts test/services/task.service.test.ts",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:create": "prisma migrate dev --create-only",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "db:status": "prisma migrate status",
    "db:fresh": "prisma migrate reset --force && prisma db seed"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.16",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.16",
    "@nestjs/platform-express": "^11.1.16",
    "@nestjs/platform-socket.io": "^11.1.16",
    "@nestjs/serve-static": "^5.0.4",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/websockets": "^11.1.16",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "@superboard/shared": "0.1.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@willsoto/nestjs-prometheus": "^6.1.0",
    "bullmq": "^5.58.0",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^8.0.4",
    "pg": "^8.16.3",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "prom-client": "^15.1.3",
    "redis": "^5.11.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "socket.io": "^4.8.3",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^25.5.0",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.15.5",
    "prisma": "^7.5.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.20.6"
  }
}
