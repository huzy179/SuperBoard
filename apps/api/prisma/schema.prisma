generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Workspace {
  id            String           @id @default(cuid())
  name          String
  slug          String           @unique
  plan          WorkspacePlan    @default(free)
  storageUsed   BigInt           @default(0)
  storageQuota  BigInt           @default(5368709120)
  deletedAt     DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  defaultUsers  User[]           @relation("DefaultWorkspace")
  members       WorkspaceMember[]
  userRoles     UserRole[]
  projects      Project[]
  workflowStatusTemplates WorkspaceWorkflowStatus[]
  workflowTemplateTransitions WorkspaceWorkflowTransition[]
  notifications Notification[]
  invitations WorkspaceInvitation[]
  labels        Label[]
  auditLogs     AuditLog[]
  channels      Channel[]
  docs          Doc[]
  workflowRules WorkflowRule[]

  @@index([deletedAt])
}

model User {
  id                 String            @id @default(cuid())
  keycloakId         String?           @unique
  email              String            @unique
  passwordHash       String
  fullName           String
  username           String?           @unique
  avatarUrl          String?
  avatarColor        String?
  isActive           Boolean           @default(true)
  lastLoginAt        DateTime?
  deletedAt          DateTime?
  defaultWorkspaceId String?
  defaultWorkspace   Workspace?        @relation("DefaultWorkspace", fields: [defaultWorkspaceId], references: [id], onDelete: SetNull)
  memberships        WorkspaceMember[]
  assignedRoles      UserRole[]
  assignedTasks      Task[]            @relation("TaskAssignee")
  taskEvents         TaskEvent[]
  comments           Comment[]
  notifications      Notification[]
  sentWorkspaceInvitations WorkspaceInvitation[]
  preferences        NotificationPreference?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  aiSkillProfile     Json?             // Inferred skills and velocity tokens
  auditLogs          AuditLog[]
  channelMembers     ChannelMember[]
  messages           Message[]
  messageReactions   MessageReaction[]
  docs               Doc[]                 @relation("DocCreator")
}

model NotificationPreference {
  id                   String   @id @default(cuid())
  userId               String   @unique
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  emailEnabled         Boolean  @default(true)
  inAppEnabled         Boolean  @default(true)
  taskAssignedEmail    Boolean  @default(true)
  workspaceInviteEmail Boolean  @default(true)
  commentMentionEmail  Boolean  @default(true)
  commentMentionInApp  Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model WorkspaceMember {
  id          String              @id @default(cuid())
  workspaceId String
  userId      String
  role        WorkspaceMemberRole @default(member)
  deletedAt   DateTime?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  workspace   Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([userId])
}

model Role {
  id          String           @id @default(cuid())
  key         String           @unique
  name        String
  description String?
  isSystem    Boolean          @default(true)
  deletedAt   DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  permissions RolePermission[]
  users       UserRole[]
}

model Permission {
  id          String           @id @default(cuid())
  key         String           @unique
  description String?
  deletedAt   DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  roles       RolePermission[]
}

model RolePermission {
  id           String     @id @default(cuid())
  roleId       String
  permissionId String
  deletedAt    DateTime?
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([permissionId])
}

model UserRole {
  id          String    @id @default(cuid())
  userId      String
  roleId      String
  workspaceId String
  assignedAt  DateTime  @default(now())
  deletedAt   DateTime?
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  role        Role      @relation(fields: [roleId], references: [id], onDelete: Cascade)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId, workspaceId])
  @@index([roleId])
  @@index([workspaceId])
}

enum WorkspaceMemberRole {
  owner
  admin
  member
  viewer
}

enum WorkspacePlan {
  free
  pro
  enterprise
}

model Project {
  id          String    @id @default(cuid())
  name        String
  description String?
  color       String?
  icon        String?
  key         String?
  deletedAt   DateTime?
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workflowStatuses ProjectWorkflowStatus[]
  workflowTransitions ProjectWorkflowTransition[]
  tasks       Task[]
  workflowRules WorkflowRule[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  embedding   ProjectEmbedding?
  memoirs     ProjectMemoir[]

  @@unique([workspaceId, key])
  @@index([workspaceId, deletedAt])
}

model ProjectMemoir {
  id          String    @id @default(cuid())
  projectId   String
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title       String
  content     String    @db.Text
  persona     String    // e.g., 'executive', 'technical', 'celebratory'
  createdAt   DateTime  @default(now())

  @@index([projectId])
}

model Task {
  id          String       @id @default(cuid())
  title       String
  description String?
  status      String       @default("todo")
  priority    TaskPriority @default(medium)
  type        TaskType     @default(task)
  number      Int?
  storyPoints Int?
  position    String?
  dueDate     DateTime?
  deletedAt   DateTime?
  parentTaskId String?
  parentTask  Task?        @relation("TaskSubtasks", fields: [parentTaskId], references: [id], onDelete: SetNull)
  subtasks    Task[]       @relation("TaskSubtasks")
  assigneeId  String?
  assignee    User?        @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  projectId   String
  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  workflowStatus ProjectWorkflowStatus @relation(fields: [projectId, status], references: [projectId, key], onDelete: Restrict)
  events      TaskEvent[]
  comments    Comment[]
  attachments Attachment[]
  labels      TaskLabel[]
  sourceLinks TaskLink[]   @relation("SourceTaskLinks")
  targetLinks TaskLink[]   @relation("TargetTaskLinks")
  embedding   TaskEmbedding?
  summary     String?      // AI-generated scannability summary
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@unique([projectId, number])
  @@index([projectId, status, deletedAt])
  @@index([parentTaskId])
  @@index([assigneeId])
}

model TaskLink {
  id           String       @id @default(cuid())
  sourceTaskId String
  targetTaskId String
  type         TaskLinkType @default(relates_to)
  createdAt    DateTime     @default(now())

  sourceTask Task @relation("SourceTaskLinks", fields: [sourceTaskId], references: [id], onDelete: Cascade)
  targetTask Task @relation("TargetTaskLinks", fields: [targetTaskId], references: [id], onDelete: Cascade)

  @@unique([sourceTaskId, targetTaskId, type])
  @@index([sourceTaskId])
  @@index([targetTaskId])
}

enum TaskLinkType {
  blocks
  relates_to
  duplicates
}

model TaskEmbedding {
  taskId    String                      @id
  task      Task                        @relation(fields: [taskId], references: [id], onDelete: Cascade)
  vector    Unsupported("vector(768)")
  updatedAt DateTime                    @updatedAt
}

model ProjectEmbedding {
  projectId String                      @id
  project   Project                     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  vector    Unsupported("vector(768)")
  updatedAt DateTime                    @updatedAt
}

model WorkspaceWorkflowStatus {
  id          String  @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  key         String
  name        String
  category    WorkflowStatusCategory
  position    Int
  isSystem    Boolean @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  transitionsFrom WorkspaceWorkflowTransition[] @relation("WorkspaceTransitionFrom")
  transitionsTo   WorkspaceWorkflowTransition[] @relation("WorkspaceTransitionTo")

  @@unique([workspaceId, key])
  @@index([workspaceId, position])
}

model WorkspaceWorkflowTransition {
  id           String @id @default(cuid())
  workspaceId  String
  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  fromStatusId String
  toStatusId   String
  fromStatus   WorkspaceWorkflowStatus @relation("WorkspaceTransitionFrom", fields: [fromStatusId], references: [id], onDelete: Cascade)
  toStatus     WorkspaceWorkflowStatus @relation("WorkspaceTransitionTo", fields: [toStatusId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, fromStatusId, toStatusId])
  @@index([workspaceId, fromStatusId])
  @@index([workspaceId, toStatusId])
}

model ProjectWorkflowStatus {
  id          String @id @default(cuid())
  projectId   String
  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  key         String
  name        String
  category    WorkflowStatusCategory
  position    Int
  isSystem    Boolean @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tasks       Task[]
  transitionsFrom ProjectWorkflowTransition[] @relation("ProjectTransitionFrom")
  transitionsTo   ProjectWorkflowTransition[] @relation("ProjectTransitionTo")

  @@unique([projectId, key])
  @@index([projectId, position])
}

model ProjectWorkflowTransition {
  id           String @id @default(cuid())
  projectId    String
  project      Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  fromStatusId String
  toStatusId   String
  fromStatus   ProjectWorkflowStatus @relation("ProjectTransitionFrom", fields: [fromStatusId], references: [id], onDelete: Cascade)
  toStatus     ProjectWorkflowStatus @relation("ProjectTransitionTo", fields: [toStatusId], references: [id], onDelete: Cascade)

  @@unique([projectId, fromStatusId, toStatusId])
  @@index([projectId, fromStatusId])
  @@index([projectId, toStatusId])
}

enum WorkflowStatusCategory {
  todo
  in_progress
  in_review
  done
  blocked
}

enum TaskPriority {
  low
  medium
  high
  urgent
}

enum TaskType {
  task
  bug
  story
  epic
}

model TaskEvent {
  id        String        @id @default(cuid())
  taskId     String
  actorId    String?
  type       TaskEventType
  payload    Json?
  deletedAt  DateTime?
  createdAt  DateTime      @default(now())
  task       Task          @relation(fields: [taskId], references: [id], onDelete: Cascade)
  actor      User?         @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([taskId, createdAt])
}

enum TaskEventType {
  created
  updated
  status_changed
  assignee_changed
  comment_added
}

model Comment {
  id        String   @id @default(cuid())
  taskId     String
  authorId   String
  content    String
  deletedAt  DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  task       Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author     User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([taskId, createdAt])
  @@index([authorId])
}

model Attachment {
  id         String    @id @default(cuid())
  name       String
  key        String    @unique
  url        String
  size       BigInt
  mimeType   String
  taskId     String?
  task       Task?     @relation(fields: [taskId], references: [id], onDelete: SetNull)
  aiContext  String?   @db.Text
  aiMetadata Json?
  deletedAt  DateTime?
  createdAt  DateTime  @default(now())

  @@index([taskId])
}

model Notification {
  id          String   @id @default(cuid())
  userId      String
  workspaceId String
  type        String
  payload        Json
  neuralPriority String    @default("AMBIENT")
  aiSummary      String?   @db.Text
  readAt         DateTime?
  deletedAt   DateTime?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([workspaceId, createdAt])
}

model WorkspaceInvitation {
  id         String                    @id @default(cuid())
  workspaceId String
  inviterId  String
  email      String
  tokenHash  String                    @unique
  role       WorkspaceMemberRole       @default(member)
  status     WorkspaceInvitationStatus @default(pending)
  expiresAt  DateTime
  acceptedAt DateTime?
  revokedAt  DateTime?
  createdAt  DateTime                  @default(now())
  updatedAt  DateTime                  @updatedAt
  workspace  Workspace                 @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  inviter    User                      @relation(fields: [inviterId], references: [id], onDelete: Cascade)

  @@index([workspaceId, status])
  @@index([workspaceId, email, status])
  @@index([inviterId])
}

model Label {
  id          String      @id @default(cuid())
  name        String
  color       String
  workspaceId String
  workspace   Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  tasks       TaskLabel[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@unique([workspaceId, name])
}

model TaskLabel {
  taskId  String
  labelId String
  task    Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  label   Label  @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([taskId, labelId])
  @@index([labelId])
}

enum WorkspaceInvitationStatus {
  pending
  accepted
  revoked
  expired
}

model AuditLog {
  id          String   @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  actorId     String?
  actor       User?     @relation(fields: [actorId], references: [id], onDelete: SetNull)
  action      String    // e.g., "member_added", "role_changed", "project_deleted"
  entityType  String    // "workspace", "project", "member"
  entityId    String
  payload     Json?     // Old/New values
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  @@index([workspaceId, createdAt])
  @@index([entityType, entityId])
}

model Channel {
  id           String          @id @default(cuid())
  workspaceId  String
  workspace    Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name         String
  description  String?
  type         ChannelType     @default(public)
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  members      ChannelMember[]
  messages     Message[]

  @@unique([workspaceId, name])
  @@index([workspaceId])
}

model ChannelMember {
  id         String   @id @default(cuid())
  channelId  String
  userId     String
  lastReadAt DateTime @default(now())
  joinedAt   DateTime @default(now())
  channel    Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([channelId, userId])
  @@index([userId])
}

model Message {
  id        String            @id @default(cuid())
  channelId String
  authorId  String
  content   String
  parentId  String? // For threading
  editedAt  DateTime?
  deletedAt DateTime?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  channel   Channel           @relation(fields: [channelId], references: [id], onDelete: Cascade)
  author    User              @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent    Message?          @relation("MessageThread", fields: [parentId], references: [id], onDelete: SetNull)
  replies   Message[]         @relation("MessageThread")
  reactions MessageReaction[]

  @@index([channelId, createdAt])
  @@index([authorId])
}

model MessageReaction {
  id        String   @id @default(cuid())
  messageId String
  userId    String
  emoji     String
  createdAt DateTime @default(now())
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
}

model Doc {
  id           String       @id @default(cuid())
  workspaceId  String
  workspace    Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  title        String
  content      Json? // TipTap JSON
  parentDocId  String?
  createdById  String
  lastEditedBy String?
  deletedAt    DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  parent       Doc?         @relation("DocTree", fields: [parentDocId], references: [id], onDelete: SetNull)
  children     Doc[]        @relation("DocTree")
  creator      User         @relation("DocCreator", fields: [createdById], references: [id], onDelete: Cascade)
  versions     DocVersion[]
  embedding    DocEmbedding?
  summary      String?      // AI-generated scannability summary
  projectId    String?
  project      Project?     @relation(fields: [projectId], references: [id], onDelete: SetNull)
  taskLinks    TaskDocLink[]

  @@index([workspaceId])
  @@index([parentDocId])
  @@index([projectId])
}

model TaskDocLink {
  id        String   @id @default(cuid())
  taskId    String
  docId     String
  type      String   @default("manual") // manual, suggested
  strength  Float    @default(1.0)
  createdAt DateTime @default(now())
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  doc       Doc      @relation(fields: [docId], references: [id], onDelete: Cascade)

  @@unique([taskId, docId])
}

model DocVersion {
  id        String   @id @default(cuid())
  docId     String
  content   Json // Snapshot
  savedAt   DateTime @default(now())
  doc       Doc      @relation(fields: [docId], references: [id], onDelete: Cascade)

  @@index([docId, savedAt])
}

model DocEmbedding {
  docId     String                      @id
  doc       Doc                         @relation(fields: [docId], references: [id], onDelete: Cascade)
  vector    Unsupported("vector(768)")
  updatedAt DateTime                    @updatedAt
}

enum ChannelType {
  public
  private
}

model WorkflowRule {
  id          String    @id @default(cuid())
  workspaceId String
  projectId   String?   // If null, it's workspace-wide
  name        String
  description String?
  isActive    Boolean   @default(true)
  trigger     Json
  actions     Json
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project     Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([workspaceId, isActive])
  @@index([projectId, isActive])
}

model AgentAction {
  id          String    @id @default(cuid())
  workspaceId String
  projectId   String?
  agentName   String
  actionType  String
  targetId    String
  reason      String    @db.Text
  metadata    Json?
  createdAt   DateTime  @default(now())
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project     Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([projectId])
}

enum IntegrationProvider {
  SLACK
  DISCORD
  GITHUB
  GITLAB
  ZAPIER
}

model ExternalIntegration {
  id          String              @id @default(cuid())
  workspaceId String
  projectId   String?
  name        String
  provider    IntegrationProvider
  type        String              // "webhook_out", "webhook_in", "oauth"
  config      Json                // { url: "...", token: "..." }
  status      String              @default("active") // "active", "error", "disabled"
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project     Project?  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([projectId])
}

model SignalLog {
  id            String              @id @default(cuid())
  workspaceId   String
  projectId     String?
  integrationId String
  provider      IntegrationProvider
  payload       Json
  interpretation String             @db.Text
  createdAt     DateTime            @default(now())

  workspace     Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project       Project?            @relation(fields: [projectId], references: [id], onDelete: SetNull)
  integration   ExternalIntegration @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  embedding     SignalEmbedding?

  @@index([workspaceId])
  @@index([projectId])
}

model SignalEmbedding {
  signalId  String                      @id
  signal    SignalLog                   @relation(fields: [signalId], references: [id], onDelete: Cascade)
  vector    Unsupported("vector(768)")
  updatedAt DateTime                    @updatedAt
}
