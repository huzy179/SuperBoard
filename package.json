{
  "name": "superboard",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@10.9.2",
  "description": "SuperBoard monorepo",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "setup": "node scripts/setup.mjs",
    "prepare": "husky",
    "dev": "turbo run dev --parallel",
    "dev:infra": "docker compose --env-file docker/compose/.env -f docker/compose/docker-compose.yml up -d",
    "dev:docker": "docker compose --env-file docker/compose/.env -f docker/compose/docker-compose.yml --profile app up -d",
    "dev:docker:hot": "docker compose --env-file docker/compose/.env -f docker/compose/docker-compose.yml -f docker/compose/docker-compose.dev.yml --profile app --profile full up",
    "dev:infra:full": "docker compose --env-file docker/compose/.env -f docker/compose/docker-compose.yml --profile full up -d",
    "dev:infra:down": "docker compose --env-file docker/compose/.env -f docker/compose/docker-compose.yml down",
    "health:check": "node scripts/health-check.mjs",
    "dev:start": "bash scripts/dev-start.sh",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "npm --ws --if-present run test",
    "format": "prettier --write .",
    "commit": "cz",
    "tech-debt": "tsx scripts/tech-debt-report.ts",
    "ui": "node scripts/ui.mjs"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "lint-staged": {
    "*.{js,mjs,cjs,ts,tsx,json,md,yml,yaml}": [
      "prettier --write"
    ],
    "{apps,packages,scripts}/**/*.{ts,tsx,js,mjs,cjs}": [
      "eslint --fix"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@prisma/client": "^7.8.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "chalk": "^4.1.2",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^9.22.0",
    "eslint-plugin-boundaries": "^5.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "prettier": "^3.5.3",
    "prisma": "^7.8.0",
    "turbo": "^2.4.4",
    "typescript": "^5.8.2"
  },
  "overrides": {
    "@hono/node-server": "1.19.13",
    "hono": "4.12.14",
    "lodash": "4.17.23"
  },
  "engines": {
    "node": ">=20.11.0"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  }
}
