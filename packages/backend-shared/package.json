{
  "name": "@superboard/backend-shared",
  "version": "0.1.0",
  "private": true,
  "description": "Shared backend infrastructure components for SuperBoard microservices",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./amqp": {
      "import": "./dist/amqp/index.js",
      "require": "./dist/amqp/index.js",
      "types": "./dist/amqp/index.d.ts"
    },
    "./health": {
      "import": "./dist/health/index.js",
      "require": "./dist/health/index.js",
      "types": "./dist/health/index.d.ts"
    },
    "./config": {
      "import": "./dist/config/index.js",
      "require": "./dist/config/index.js",
      "types": "./dist/config/index.d.ts"
    },
    "./events": {
      "import": "./dist/events/index.js",
      "require": "./dist/events/index.js",
      "types": "./dist/events/index.d.ts"
    },
    "./metrics": {
      "import": "./dist/metrics/index.js",
      "require": "./dist/metrics/index.js",
      "types": "./dist/metrics/index.d.ts"
    },
    "./bootstrap": {
      "import": "./dist/bootstrap/index.js",
      "require": "./dist/bootstrap/index.js",
      "types": "./dist/bootstrap/index.d.ts"
    },
    "./connections": {
      "import": "./dist/connections/index.js",
      "require": "./dist/connections/index.js",
      "types": "./dist/connections/index.d.ts"
    },
    "./errors": {
      "import": "./dist/errors/index.js",
      "require": "./dist/errors/index.js",
      "types": "./dist/errors/index.d.ts"
    },
    "./testing": {
      "import": "./dist/testing/index.js",
      "require": "./dist/testing/index.js",
      "types": "./dist/testing/index.d.ts"
    }
  },
  "files": [
    "dist/**/*",
    "python/**/*",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:python": "cd python && python setup.py sdist bdist_wheel",
    "dev": "tsc -p tsconfig.json --watch",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:python": "cd python && python -m pytest",
    "clean": "rm -rf dist && rm -rf python/dist && rm -rf python/build",
    "prepublishOnly": "npm run clean && npm run build && npm run build:python"
  },
  "keywords": [
    "superboard",
    "backend",
    "shared",
    "infrastructure",
    "microservices",
    "amqp",
    "health-check",
    "configuration",
    "metrics"
  ],
  "author": "SuperBoard Team",
  "license": "MIT",
  "dependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/terminus": "^10.0.0",
    "amqplib": "^0.10.0",
    "ioredis": "^5.0.0",
    "js-yaml": "^4.1.0",
    "mysql2": "^3.0.0",
    "pg": "^8.0.0",
    "prom-client": "^15.0.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.0.0",
    "zod": "^3.22.0",
    "winston": "^3.10.0"
  },
  "devDependencies": {
    "@superboard/config-ts": "0.1.0",
    "@superboard/shared": "0.2.0",
    "@types/amqplib": "^0.10.0",
    "@types/jest": "^29.0.0",
    "@types/js-yaml": "^4.0.0",
    "@types/node": "^20.0.0",
    "@types/pg": "^8.0.0",
    "fast-check": "^3.23.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "typescript": "^5.0.0",
    "eslint": "^9.0.0"
  },
  "peerDependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0"
  },
  "engines": {
    "node": ">=20.11.0",
    "python": ">=3.9"
  }
}
